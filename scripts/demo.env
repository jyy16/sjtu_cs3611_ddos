# Copy this file to scripts/demo.env, then adjust values for your lab.
# Keep TARGET_IP in loopback/private ranges only. Never use a public target.

PYTHON=python3
SUDO=sudo

# Local demo defaults. For Mininet, set START_TARGET=0 and use the victim host IP.
TARGET_IP=127.0.0.1
TARGET_PORT=8080
TARGET_URL=http://127.0.0.1:8080/
CAPTURE_IFACE=lo
START_TARGET=1
TARGET_SITE_DIR=demo_site

# Demo duration and traffic rates. Keep rates modest for class demos.
NORMAL_SECONDS=10
ATTACK_SECONDS=20
NORMAL_RATE=5
SYN_RATE=200
HTTP_RATE=80
UDP_RATE=100

# Basic defense thresholds.
SYN_LIMIT=50
HTTP_LIMIT=120
CONFIDENCE_THRESHOLD=0.80
DEFENSE_BACKEND=iptables

# Optional nftables backend:
# DEFENSE_BACKEND=nftables
#
# Optional nginx edge demo:
# Start the origin on 127.0.0.1:8080, run nginx with defense/nginx.conf,
# then send HTTP traffic through the edge by overriding TARGET_URL:
# TARGET_URL=http://127.0.0.1:8081/

# Model and training files.
MODEL_PATH=models/saved/model.pth
TRAIN_FEATURES=data/features/train.csv
TRAIN=0

# Output tag and folder suffix.
PROJECT_TAG=cs3611-ddos
